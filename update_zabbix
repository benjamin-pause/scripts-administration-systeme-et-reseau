#!/bin/bash
# update_zabbix.sh
# Met à jour les composants Zabbix (server, frontend, agent) sur une distribution Debian/Ubuntu
# Adaptez les noms de paquets selon votre installation (MySQL/PostgreSQL, Apache/Nginx)
# Usage : sudo ./update_zabbix.sh

LOG_FILE="/var/log/update_zabbix.log"

echo "=== Mise à jour de Zabbix - $(date) ===" | tee -a "$LOG_FILE"

if [ "$EUID" -ne 0 ]; then
  echo "Ce script doit être exécuté en root (sudo)."
  exit 1
fi

echo "[1/3] Mise à jour de la liste des paquets..."
apt update -y >> "$LOG_FILE" 2>&1

echo "[2/3] Mise à niveau des composants Zabbix installés..."
apt install --only-upgrade -y \
  zabbix-server-mysql \
  zabbix-frontend-php \
  zabbix-agent \
  zabbix-sql-scripts >> "$LOG_FILE" 2>&1

echo "[3/3] Redémarrage des services Zabbix..."
systemctl restart zabbix-server
systemctl restart zabbix-agent
systemctl restart apache2 2>/dev/null || systemctl restart nginx 2>/dev/null

echo "Mise à jour de Zabbix terminée. Log disponible dans $LOG_FILE"
echo "Vérifiez la version installée avec : zabbix_server --version"
